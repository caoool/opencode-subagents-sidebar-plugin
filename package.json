{
  "name": "opencode-subagents-sidebar-plugin",
  "version": "0.1.4",
  "description": "OpenCode TUI sidebar footer for active subagents.",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tui",
    "subagents"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/caoool/opencode-subagents-sidebar-plugin.git"
  },
  "exports": {
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js",
      "default": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "opencode": ">=1.17.15"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc --project tsconfig.build.json && babel src --extensions .ts,.tsx --out-dir dist --source-maps",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs",
    "check": "npm run typecheck && npm test"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.17.15",
    "@opentui/solid": "0.4.3",
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@babel/cli": "7.28.0",
    "@babel/core": "7.28.0",
    "@babel/preset-typescript": "7.27.1",
    "babel-preset-solid": "1.9.12",
    "typescript": "5.9.3"
  }
}
